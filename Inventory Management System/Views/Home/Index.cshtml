@{
    ViewData["Title"] = "Home Page";
}
<link rel="stylesheet" href="/datatables/jquery.dataTables.min.css" />

<link href="~/css/Inventory.css" rel="stylesheet" />


<div class="container mt-4">
    <div class="card p-4">
        <div class="d-flex justify-content-between mb-3">
            <h2>Welcome to the Inventory Management System</h2>
         
            <button class="btn btn-primary" onclick="openModal()">+ Add Products</button>
        </div>
        <!-- ===== DASHBOARD CARDS ===== -->
        <div class="row mb-4">

            <div class="col-md-3">
                <div class="card dashboard-card bg-primary text-white">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6>Total Products</h6>
                            <h3 id="totalProducts">0</h3>
                        </div>
                        <div class="icon">📦</div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card dashboard-card bg-success text-white">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6>Categories</h6>
                            <h3 id="totalCategories">0</h3>
                        </div>
                        <div class="icon">📂</div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card dashboard-card bg-warning text-white">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6>Suppliers</h6>
                            <h3 id="totalSuppliers">0</h3>
                        </div>
                        <div class="icon">🚚</div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card dashboard-card bg-danger text-white">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6>Low Stock</h6>
                            <h3 id="lowStock">0</h3>
                        </div>
                        <div class="icon">⚠</div>
                    </div>
                </div>
            </div>

        </div>

        <div class="row">

            <div class="col-md-6">
                <div class="card chart-card">
                    <h6 class="mb-3">📊 Category Wise Products</h6>
                    <div style="height:250px;">
                        <canvas id="barChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card chart-card">
                    <h6 class="mb-3">🍕 Category Distribution</h6>
                    <div style="height:250px;">
                        <canvas id="pieChart"></canvas>
                    </div>
                </div>
            </div>

        </div>
        
        <table id="productTable" class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Product Name</th>
                    <th>Category</th>
                    <th>Supplier</th>
                    <th>Price</th>
                    <th>Stock Quantity</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="tblData"></tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="productModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modern-modal">

            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">📦 Add Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="Id" />

                <div class="form-floating mb-3">
                    <input type="text" class="form-control input-modern" id="Name" placeholder="Product Name">
                    <label>Product Name</label>
                    <span class="error" id="errName"></span>
                </div>

                <div class="form-floating mb-3">
                    <select class="form-control input-modern" id="CategoryId"></select>
                    <label>Category</label>
                    <span class="error" id="errCategory"></span>
                </div>

                <div class="form-floating mb-3">
                    <select class="form-control input-modern" id="SupplierId"></select>
                    <label>Supplier</label>
                    <span class="error" id="errSupplier"></span>
                </div>

                <div class="form-floating mb-3">
                    <input type="number" class="form-control input-modern" id="Price" placeholder="Price">
                    <label>Price</label>
                    <span class="error" id="errPrice"></span>
                </div>

                <div class="form-floating mb-3">
                    <input type="number" class="form-control input-modern" id="Quantity" placeholder="Quantity">
                    <label>Quantity</label>
                    <span class="error" id="errQty"></span>
                </div>

            </div>

            <div class="modal-footer border-0 d-flex justify-content-between">

                <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>

                <button class="btn btn-success px-4" id="btnSave" onclick="saveProduct()">
                    <span id="btnText">💾 Save</span>
                    <span id="btnLoader" class="spinner-border spinner-border-sm d-none"></span>
                </button>

            </div>

        </div>
    </div>
</div>

@section Scripts {

    <script src="/datatables/jquery.dataTables.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/js/Inventory.js"></script>

   

}

